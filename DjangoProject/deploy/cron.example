# Every day at 02:30 backup SQLite database
30 2 * * * /opt/smartpoultry/scripts/backup_sqlite.sh >> /var/log/smartpoultry-backup.log 2>&1

# Every day at 03:00 check overdue receivables and create notifications/incidents
0 3 * * * /opt/smartpoultry/.venv/bin/python /opt/smartpoultry/manage.py check_overdue_sales >> /var/log/smartpoultry-overdue.log 2>&1
